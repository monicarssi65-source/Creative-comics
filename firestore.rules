rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default-Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // Mandate authenticated session with verified email for write operations
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation for Character entity
    function isValidCharacter(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'description', 'appearance', 'avatarUrl', 'accentColor', 'userId'])
        && data.keys().size() <= 9
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.role is string && data.role in ['Hero', 'Sidekick', 'Villain', 'Narrator', 'Neutral']
        && data.description is string && data.description.size() <= 2000
        && data.appearance is string && data.appearance.size() <= 2000
        && data.avatarUrl is string && data.avatarUrl.size() <= 1000000
        && data.accentColor is string && data.accentColor.size() <= 30
        && data.userId == request.auth.uid;
    }

    // Schema Validation for Comic entity
    function isValidComic(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'style', 'characters', 'panels', 'createdAt', 'userId'])
        && data.keys().size() == 8
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.description is string && data.description.size() <= 4000
        && data.style is string && data.style in ['Manga', 'Superhero', 'Cartoon', 'Noir', 'Watercolor', 'DigitalArt']
        && data.createdAt is string && data.createdAt.size() <= 100
        && data.characters is list && data.characters.size() <= 50
        && data.panels is list
        && data.userId == request.auth.uid;
    }

    // Characters Collection Rules Set
    match /characters/{characterId} {
      allow get: if isEmailVerified() && resource.data.userId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.userId == request.auth.uid;
      
      allow create: if isEmailVerified() 
        && isValidId(characterId) 
        && isValidCharacter(request.resource.data)
        && request.resource.data.id == characterId;
        
      allow update: if isEmailVerified()
        && isValidId(characterId)
        && isValidCharacter(request.resource.data)
        // Immutable field checks
        && request.resource.data.id == resource.data.id
        && request.resource.data.userId == resource.data.userId;
        
      allow delete: if isEmailVerified() 
        && isValidId(characterId)
        && resource.data.userId == request.auth.uid;
    }

    // Comics Collection Rules Set
    match /comics/{comicId} {
      allow get: if isEmailVerified() && resource.data.userId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.userId == request.auth.uid;
      
      allow create: if isEmailVerified()
        && isValidId(comicId)
        && isValidComic(request.resource.data)
        && request.resource.data.id == comicId;
        
      allow update: if isEmailVerified()
        && isValidId(comicId)
        && isValidComic(request.resource.data)
        // Immutable field checks
        && request.resource.data.id == resource.data.id
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;
        
      allow delete: if isEmailVerified()
        && isValidId(comicId)
        && resource.data.userId == request.auth.uid;
    }
  }
}
